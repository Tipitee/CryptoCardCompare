# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Hugging Face API Token (for image generation)
# Get your token at: https://huggingface.co/settings/tokens
# Required for: /admin-hero-images (generating article hero images)
# This should be set as a secret in Supabase Edge Functions, not in this .env file
# HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API Key (for Claude prompt generation)
# Required for: generating optimized prompts for images
# This should be set as a secret in Supabase Edge Functions
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Admin Secret (for admin endpoints)
# This should be set as a secret in Supabase Edge Functions
# ADMIN_SECRET=your-secure-admin-password-here
